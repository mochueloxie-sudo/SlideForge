# ─── MiniMax LLM（必填）─────────────────────────────────────────────────────────
# Step 0 内容分析 + Step 1 逐字稿生成
MINIMAX_API_KEY=sk-your-minimax-api-key-here
MINIMAX_MODEL=MiniMax-M2.7-highspeed
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# ─── 飞书 Open API（按需填写）────────────────────────────────────────────────────
# Step 0 读取飞书文档 / Step 7 发布到飞书文档
# 创建方式：https://open.feishu.cn/app → 创建企业自建应用 → 获取 App ID / Secret
# 所需权限：docx:document（读取文档）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here

# ─── 可选配置 ────────────────────────────────────────────────────────────────────
# 手动指定 lark-cli 路径（通常不需要，Step 7 会自动查找）
# LARK_CLI_PATH=/usr/local/bin/lark-cli

# Chrome 可执行文件路径（Puppeteer 自动检测，通常不需要指定）
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
