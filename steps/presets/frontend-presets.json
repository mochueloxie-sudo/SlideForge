      "name": "Bold Signal",
      "vibe": "Confident, bold, modern, high-impact",
      "layoutHint": "center_focus",
      "cssVars": {
        "--bg-primary": "#1a1a1a",
        "--bg-gradient": "linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 50%, #1a1a1a 100%)",
        "--card-bg": "#FF5722",
        "--text-primary": "#ffffff",
        "--text-on-card": "#1a1a1a"
      },
      "displayFont": "Archivo Black",
      "bodyFont": "Space Grotesk",
      "signatureElements": [
        "colored-card",
        "section-numbers",
        "nav-breadcrumbs"
      ],
      "panel": {
        "enabled": true,
        "background": "rgba(35,35,35,0.80)",
        "border": "1px solid rgba(255,87,34,0.25)",
        "borderTop": "1px solid rgba(255,150,100,0.15)",
        "borderBottom": "1px solid rgba(0,0,0,0.35)",
        "shadow": "0 20px 60px rgba(0,0,0,0.45), 0 4px 12px rgba(0,0,0,0.25)",
        "innerGlow": "inset 0 1px 0 rgba(255,150,100,0.12)",
        "radius": "20px",
        "blur": "8px"
      }
    },
